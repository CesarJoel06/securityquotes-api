{
  "info": {
    "name": "SecurityQuotes API - VPS 62.169.22.80",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección para probar login, generación de PDF, endpoints administrativos y consultas de usuarios/documentos."
  },
  "variable": [
    { "key": "base_url", "value": "http://62.169.22.80:3000" },
    { "key": "admin_api_key", "value": "kjkszpj" },
    { "key": "email", "value": "correo@ejemplo.com" },
    { "key": "password", "value": "123456" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/health"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{base_url}}/api/auth/login"
      }
    },
    {
      "name": "Generar PDF autenticado",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientName\": \"Cliente autenticado\",\n  \"documentType\": \"Cotización\",\n  \"services\": [\"Instalación de cámaras\", \"Configuración de DVR\"],\n  \"materials\": [\"Cable UTP\", \"Conectores\", \"Fuente\"],\n  \"total\": 350\n}"
        },
        "url": "{{base_url}}/api/documents"
      }
    },
    {
      "name": "Listar mis documentos",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{base_url}}/api/documents"
      }
    },
    {
      "name": "Admin - listar usuarios",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-api-key", "value": "{{admin_api_key}}" }
        ],
        "url": "{{base_url}}/api/admin/users"
      }
    },
    {
      "name": "Admin - documentos de usuario",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-api-key", "value": "{{admin_api_key}}" }
        ],
        "url": "{{base_url}}/api/admin/users/{{user_id}}/documents"
      }
    },
    {
      "name": "Admin - generar PDF por userId",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-api-key", "value": "{{admin_api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{user_id}},\n  \"clientName\": \"Cliente generado desde Postman\",\n  \"documentType\": \"Venta\",\n  \"services\": \"Servicio técnico\\nCambio de conectores\\nPruebas\",\n  \"materials\": \"Balún\\nConector DC\\nFuente\",\n  \"total\": \"80.00\"\n}"
        },
        "url": "{{base_url}}/api/admin/documents"
      }
    }
  ]
}
